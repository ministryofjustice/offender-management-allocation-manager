<% if failed_cases.any? %>
  <div class="govuk-error-summary" data-module="govuk-error-summary">
    <div role="alert">
      <h2 class="govuk-error-summary__title">
        <% if failed_cases.one? %>
          One case could not be reallocated
        <% else %>
          Some cases could not be reallocated
        <% end %>
      </h2>
      <div class="govuk-error-summary__body">
        <ul class="govuk-list govuk-list--bullet">
          <% failed_cases.each do |failed_case| %>
            <li><%= failed_case[:full_name] %> (<%= failed_case[:nomis_offender_id] %>)</li>
          <% end %>
        </ul>
        <p class="govuk-body">
          If the problem continues, request support by calling <%= SERVICE_DESK_NUMBER %> or
          #<%= SERVICE_DESK_EXTENSION %> from inside an establishment.
        </p>
      </div>
    </div>
  </div>
<% end %>
