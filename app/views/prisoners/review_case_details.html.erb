<% content_for :title, "Review case – Digital Prison Services" %>
<% content_for :turbolinks_nocache, 'true' %>

<%= link_to "Back", 'javascript:history.back()', class: "govuk-back-link govuk-!-margin-top-0 govuk-!-margin-bottom-6" %>
<%= render 'layouts/notice', notice: flash[:notice] %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <div class="moj-page-header-actions">
      <div class="moj-page-header-actions__title">
        <h1 class="govuk-heading-l">
          Review <%= @prisoner.first_name.capitalize %> <%= @prisoner.last_name.capitalize %>'s case
        </h1>
        <% if @allocation.present? %>
          <% if @coworking %>
            <span class="govuk-caption-l govuk-!-margin-bottom-2">Primary POM: <%= @pom.full_name_ordered %></span>
          <% elsif @pom.present? %>
            <span class="govuk-caption-l govuk-!-margin-bottom-2">Currently allocated
              to <%= @pom.full_name_ordered %></span>
          <% end %>
        <% end %>
        <span class="govuk-caption-l">Prison number: <%= @prisoner.offender_no %></span>
        <span class="govuk-caption-l govuk-!-margin-bottom-3">Date of birth: <%= format_date(@prisoner.date_of_birth) %>
          (<%= @prisoner.age %>)</span>
      </div>

      <div class="moj-page-header-actions__actions">
        <%= render partial: 'choose_pom_button', locals: { coworking: @coworking, prison: @prison, offender_no: @prisoner.offender_no } %>
      </div>
    </div>
  </div>
</div>

<div class="govuk-grid-row">

  <!-- Left column -->
  <div class="govuk-grid-column-two-thirds">

    <!-- At a glance box -->
    <div class="govuk-notification-banner" role="region" aria-labelledby="govuk-notification-banner-title" data-module="govuk-notification-banner">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="govuk-notification-banner-title">
          At a glance
        </h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading"></p>
        <p>
          <span class="govuk-tag govuk-tag--blue"><%= sentence_type_label(@prisoner) %></span>
          <%= vlo_tag(@prisoner) %>
        </p>

        <dl class="govuk-summary-list">
          <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
            <dt class="govuk-summary-list__key">Main offence</dt>
            <dd class="govuk-summary-list__value"><%= @prisoner.main_offence %></dd>
          </div>
          <div class="govuk-summary-list__row" id="tier">
            <dt class="govuk-summary-list__key">Tier</dt>
            <dd class="govuk-summary-list__value"><%= @prisoner.tier.presence || 'No tier found' %></dd>
            <dd class="govuk-summary-list__actions">
              <%= link_to('Change', edit_prison_prisoner_case_information_path(@prison, @prisoner.offender_no, from: :review_case), class: 'govuk-link govuk-link--no-visited-state') if @prisoner.manual_entry? %>
            </dd>
          </div>
          <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
            <dt class="govuk-summary-list__key">Category</dt>
            <dd class="govuk-summary-list__value"><%= @prisoner.category_code.presence || 'No category found' %></dd>
          </div>
          <div class="govuk-summary-list__row" id="rosh-row">
            <dt class="govuk-summary-list__key">ROSH</dt>
            <dd class="govuk-summary-list__value"><%= @prisoner.rosh_level.present? ? @prisoner.rosh_level.humanize : 'No ROSH found' %></dd>
            <dd class="govuk-summary-list__actions">
              <%= link_to('Change', edit_prison_prisoner_case_information_path(@prison, @prisoner.offender_no, from: :review_case),
                          class: 'govuk-link govuk-link--no-visited-state') if @prisoner.manual_entry? && FeatureFlags.rosh_level.enabled? %>
            </dd>
          </div>
          <% if @prison.womens? %>
            <div class="govuk-summary-list__row" id="complexity-level-row">
              <dt class="govuk-summary-list__key">Complexity of need level</dt>
              <dd class="govuk-summary-list__value"><%= @prisoner.complexity_level&.capitalize %></dd>
              <dd class="govuk-summary-list__actions">
                <%= link_to 'Change', edit_prison_prisoner_complexity_level_path(@prison.code, @prisoner.offender_no, from: :review_case), class: 'govuk-link govuk-link--no-visited-state' %>
              </dd>
            </div>
          <% end %>
          <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
            <dt class="govuk-summary-list__key">Sentence start date</dt>
            <dd class="govuk-summary-list__value"><%= format_date(@prisoner.sentence_start_date, replacement: 'N/A') %></dd>
          </div>
          <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
            <dt class="govuk-summary-list__key">Earliest release date</dt>
            <dd class="govuk-summary-list__value"><%= format_earliest_release_date(@prisoner.earliest_release) %></dd>
          </div>
          <div class="govuk-summary-list__row" id="service-provider-row">
            <dt class="govuk-summary-list__key">Handover type</dt>
            <dd class="govuk-summary-list__value"><%= handover_type_label(@prisoner) %></dd>
            <dd class="govuk-summary-list__actions">
              <%= link_to 'Change', edit_prison_prisoner_case_information_path(@prison.code, @prisoner.offender_no, from: :review_case), class: 'govuk-link govuk-link--no-visited-state' if @prisoner.manual_entry? %>
            </dd>
          </div>
          <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
            <dt class="govuk-summary-list__key">Location</dt>
            <dd class="govuk-summary-list__value"><%= @prisoner.location %></dd>
          </div>
          <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
            <dt class="govuk-summary-list__key">POM role needed</dt>
            <dd class="govuk-summary-list__value"><%= pom_responsibility_label(@prisoner) %></dd>
          </div>
          <% if @pom.present? %>
            <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
              <dt class="govuk-summary-list__key">POM</dt>
              <dd class="govuk-summary-list__value"><%= @pom.full_name_ordered %></dd>
            </div>
            <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
              <dt class="govuk-summary-list__key">POM email</dt>
              <dd class="govuk-summary-list__value"><%= @pom.email_address %></dd>
            </div>
            <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
              <dt class="govuk-summary-list__key">POM role</dt>
              <dd class="govuk-summary-list__value"><%= @pom.position_description %></dd>
            </div>
          <% end %>
        </dl>

        <h3 class="govuk-heading-m govuk-!-margin-top-7 govuk-!-margin-bottom-4">Key dates</h3>
        <dl class="govuk-summary-list">
          <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
            <dt class="govuk-summary-list__key">Last OASys completed</dt>
            <dd class="govuk-summary-list__value"><%= render 'oasys_assessment', assessment: @oasys_assessment %></dd>
          </div>
          <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
            <dt class="govuk-summary-list__key">COM responsible</dt>
            <dd class="govuk-summary-list__value"><%= format_date(@prisoner.responsibility_handover_date, replacement: 'Unknown') %></dd>
          </div>
        </dl>

        <% if @coworking %>
          <%= link_to 'Choose a co-working POM to allocate to now', prison_prisoner_staff_index_path(@prison, @prisoner.offender_no, coworking: true) %>
        <% else %>
          <%= link_to 'Choose a POM to allocate to now', prison_prisoner_staff_index_path(@prison, @prisoner.offender_no) %>
        <% end %>
        or see more information below before allocating.
        <p></p>
        <div aria-live="polite" role="status" aria-atomic="true" class="govuk-visually-hidden"></div>
      </div>
    </div>
    <!-- /At a glance box -->

    <!-- More info -->
    <h2 class="govuk-heading-l govuk-!-margin-top-8">More information</h2>

    <p>You can also see <%= @prisoner.first_name.capitalize %>'s:</p>

    <ul class="govuk-list govuk-list--bullet">
      <li>
        <a class="govuk-link govuk-link--no-visited-state" href="<%= ENV['DIGITAL_PRISON_SERVICE_HOST'] %>/prisoner/<%= @prisoner.offender_no %>" target="_blank">
          full Digital Prison Services profile
        </a>
      </li>
      <% if @allocation.present? %>
        <li>
          <%= link_to('allocation history', history_prison_prisoner_allocation_path(@prison, @prisoner.offender_no), class: 'govuk-link govuk-link--no-visited-state') %>
        </li>
      <% end %>
    </ul>

    <!-- Accordions -->
    <div class="govuk-accordion" data-module="govuk-accordion" id="accordion-<%= (rand * 1000000).floor %>">
      <div class="govuk-accordion__section ">
        <div class="govuk-accordion__section-header">
          <h2 class="govuk-accordion__section-heading">
            <span class="govuk-accordion__section-button" id="accordion-default-heading-1">
              Sentence and offence
            </span>
          </h2>
        </div>
        <div id="accordion-default-content-1" class="govuk-accordion__section-content">
          <table class="govuk-table">
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header"></th>
                <th scope="col" class="govuk-table__header"></th>
                <th scope="col" class="govuk-table__header"></th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              <tr class="govuk-table__row">
                <td class="govuk-table__cell govuk-!-width-one-third">Main offence</td>
                <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2"><%= @prisoner.main_offence %></td>
              </tr>
              <% if @prisoner.sentence_start_date.present? %>
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell govuk-!-width-one-third">Sentence start date</td>
                  <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2"><%= format_date(@prisoner.sentence_start_date) %></td>
                </tr>
              <% end %>
              <% if @prisoner.conditional_release_date.present? %>
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell govuk-!-width-one-third">Conditional release date</td>
                  <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2"><%= format_date(@prisoner.conditional_release_date) %></td>
                </tr>
              <% end %>
              <% if @prisoner.automatic_release_date.present? %>
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell govuk-!-width-one-third">Automatic release date</td>
                  <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2"><%= format_date(@prisoner.automatic_release_date) %></td>
                </tr>
              <% end %>
              <% if @prisoner.parole_eligibility_date.present? %>
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell govuk-!-width-one-third">Parole eligibility date</td>
                  <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2"><%= format_date(@prisoner.parole_eligibility_date) %></td>
                </tr>
              <% end %>
              <% if @prisoner.home_detention_curfew_actual_date.present? %>
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell govuk-!-width-one-third">Home detention curfew actual date</td>
                  <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2"><%= format_date(@prisoner.home_detention_curfew_actual_date) %></td>
                </tr>
              <% end %>
              <% if @prisoner.tariff_date.present? %>
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell govuk-!-width-one-third">Tariff expiry date</td>
                  <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2"><%= format_date(@prisoner.tariff_date) %></td>
                </tr>
              <% end %>
              <% if @prisoner.target_hearing_date.present? %>
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell govuk-!-width-one-third">Target hearing date</td>
                  <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2"><%= format_date(@prisoner.target_hearing_date) %></td>
                </tr>
              <% end %>
              <% if @prisoner.post_recall_release_date.present? %>
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell govuk-!-width-one-third">Post recall release date</td>
                  <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2"><%= format_date(@prisoner.post_recall_release_date) %></td>
                </tr>
              <% end %>
              <% if @prisoner.licence_expiry_date.present? %>
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell govuk-!-width-one-third">Sentence/licence end date</td>
                  <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2"><%= format_date(@prisoner.licence_expiry_date) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
      <div class="govuk-accordion__section ">
        <div class="govuk-accordion__section-header">
          <h2 class="govuk-accordion__section-heading">
            <span class="govuk-accordion__section-button" id="accordion-default-heading-2">
              Handover
            </span>
          </h2>
        </div>
        <div id="accordion-default-content-2" class="govuk-accordion__section-content">
          <table class="govuk-table">
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header"></th>
                <th scope="col" class="govuk-table__header"></th>
                <th scope="col" class="govuk-table__header"></th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              <tr class="govuk-table__row">
                <td class="govuk-table__cell govuk-!-width-one-third">LDU</td>
                <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2">
                  <%= probation_field(@prisoner, :ldu_name) || "Unknown" %>
                </td>
              </tr>
              <tr class="govuk-table__row">
                <td class="govuk-table__cell govuk-!-width-one-third">LDU email</td>
                <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2">
                  <% if probation_field(@prisoner, :ldu_email_address).present? %>
                    <%= mail_to(@prisoner.ldu_email_address, @prisoner.ldu_email_address) %>
                  <% else %>
                    Unknown
                  <% end %>
                </td>
              </tr>
              <tr class="govuk-table__row">
                <td class="govuk-table__cell govuk-!-width-one-third">COM</td>
                <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2">
                  <%= probation_field(@prisoner, :allocated_com_name) || "Unknown" %>
                </td>
              </tr>
              <tr class="govuk-table__row">
                <td class="govuk-table__cell govuk-!-width-one-third">COM email</td>
                <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2">
                  <%= probation_field(@prisoner, :allocated_com_email) || "Unknown" %>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="govuk-accordion__section ">
        <div class="govuk-accordion__section-header">
          <h2 class="govuk-accordion__section-heading">
            <span class="govuk-accordion__section-button" id="accordion-default-heading-3">
              Contacts
            </span>
          </h2>
        </div>
        <div id="accordion-default-content-3" class="govuk-accordion__section-content">
          <table class="govuk-table">
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header"></th>
                <th scope="col" class="govuk-table__header"></th>
                <th scope="col" class="govuk-table__header"></th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              <% if @prev_pom_details.present? %>
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell govuk-!-width-one-third">Previous POM</td>
                  <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2">
                    <%= render partial: 'case_history/allocation/pom_term', locals: { term: @prev_pom_details } %>
                  </td>
                </tr>

                <% if @prev_pom_details[:email].present? %>
                  <tr class="govuk-table__row">
                    <td class="govuk-table__cell govuk-!-width-one-third">Previous POM email</td>
                    <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2"><%= @prev_pom_details[:email] %></td>
                  </tr>
                <% end %>
              <% end %>

              <tr class="govuk-table__row">
                <td class="govuk-table__cell govuk-!-width-one-third">Co-working POM</td>
                <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2"><%= @secondary_pom_name || 'None allocated' %></td>
              </tr>

              <% if @secondary_pom_name.present? %>
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell govuk-!-width-one-third">Co-working POM email</td>
                  <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2"><%= @secondary_pom_email %></td>
                </tr>
              <% end %>

              <tr class="govuk-table__row">
                <td class="govuk-table__cell govuk-!-width-one-third">Key worker</td>
                <td class="govuk-table__cell govuk-!-width-two-thirds" colspan="2"><%= @keyworker.full_name %></td>
              </tr>

              <tr class="govuk-table__row">
                <td class="govuk-table__cell govuk-!-width-one-third">Victim liaison officer (VLO)
                  <br>
                  <span class="govuk-tag govuk-tag--red govuk-!-margin-top-2">Non-Disclosable</span>
                </td>

                <% if @prisoner.active_vlo? && @prisoner.victim_liaison_officers.none? %>
                  <td class="govuk-table__cell govuk-!-width-one-third" colspan="2">
                    <%= render 'shared/vlo_warning', prison_code: @prison.code, offender_no: @prisoner.offender_no %>
                  </td>
                <% elsif @prisoner.victim_liaison_officers.none? %>
                  <td class="govuk-table__cell govuk-!-width-one-third">
                    No VLO details added
                    <div class="govuk-!-margin-top-2">
                      <%= link_to 'Add new VLO contact',
                                  new_prison_prisoner_victim_liaison_officer_path(@prison.code, @prisoner.offender_no),
                                  class: 'govuk-link' %>
                    </div>
                  </td>
                  <td class="govuk-table__cell govuk-!-width-one-third"></td>
                <% else %>
                  <td class="govuk-table__cell govuk-!-width-one-third">
                    <% @prisoner.victim_liaison_officers.each do |vlo| %>
                      <div class="govuk-!-margin-bottom-3 vlo-details">
                        <%= vlo.full_name_ordered %><br/>
                        <%= vlo.email %>
                      </div>
                    <% end %>
                    <div class="govuk-!-margin-top-2">
                      <%= link_to 'Add new VLO contact',
                                  new_prison_prisoner_victim_liaison_officer_path(@prison.code, @prisoner.offender_no),
                                  class: 'govuk-link' %>
                    </div>
                  </td>
                  <td class="govuk-table__cell govuk-!-width-one-third">
                    <% @prisoner.victim_liaison_officers.each do |vlo| %>
                      <div class="govuk-!-margin-bottom-3">
                        <%= link_to 'Change details', edit_prison_prisoner_victim_liaison_officer_path(@prison.code, @prisoner.offender_no, vlo) %>
                        <br/>
                        <%= link_to 'Remove contact', delete_prison_prisoner_victim_liaison_officer_path(@prison.code, @prisoner.offender_no, vlo) %>
                      </div>
                    <% end %>
                  </td>
                <% end %>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <!-- /Accordions -->
    <!-- /More info -->

    <%= render partial: 'choose_pom_button', locals: { coworking: @coworking, prison: @prison, offender_no: @prisoner.offender_no } %>
  </div>

  <!--Right column-->
  <div class="govuk-grid-column-one-third">
    <aside role="complementary">
      <%= render partial: 'shared/mappa', locals: { mappa: @mappa } %>
      <%= render partial: 'shared/rosh', locals: { rosh: @rosh } %>
      <%= render partial: 'shared/active_alerts', locals: { alerts: @alerts, offender_no: @prisoner.offender_no } %>
    </aside>
  </div>
</div>
